# ── Google OAuth (required) ──────────────────────────────────────────────────
# Base64-encoded content of client_secret_1.json
# Generate: python -c "import base64; print(base64.b64encode(open('client_secret_1.json','rb').read()).decode())"
GOOGLE_CREDENTIALS=

# Base64-encoded content of token_1.json
# Generate: python -c "import base64; print(base64.b64encode(open('token_1.json','rb').read()).decode())"
GOOGLE_TOKEN=

# OAuth callback — must match exactly what's in Google Cloud Console
REDIRECT_URI=http://localhost:3010/api/auth/callback

# ── YouTube Data API keys (optional — trending/search) ───────────────────────
YT_API_KEY_2=

# ── AI features (optional) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Set automatically by Railway — do not configure manually ─────────────────
# PORT=
# RAILWAY_PUBLIC_DOMAIN=
